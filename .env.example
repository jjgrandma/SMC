# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_ALLOWED_USERS=123456789,987654321

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# MetaTrader 5 (optional)
MT5_ENABLED=false
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Risk Management
MAX_RISK_PERCENT=1.0
MAX_SPREAD_POINTS=30
MIN_RR_RATIO=2.0

# Trading
SYMBOL=XAUUSD
AUTO_TRADE=false

# SMC Engine
# Set to true to use github.com/joshyattridge/smart-money-concepts
# pip install smartmoneyconcepts
USE_EXTERNAL_SMC=false
